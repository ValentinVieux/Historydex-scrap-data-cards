# Credentials InstantDB pour le push:db, le wipe-db et le bouton "Push to DB"
# de l'app de review. Récupère ces valeurs depuis l'app HistoryDex (mêmes
# valeurs que dans ../app/historydex/.env), puis copie ce fichier en `.env` :
#
#   cp .env.example .env
#   # remplace les valeurs ci-dessous, puis :
#   npm run validate    # smoke test (n'utilise pas la DB)
#   npm run push:db -- --dry-run   # vérifie la connexion sans pousser

EXPO_PUBLIC_INSTANT_APP_ID=
INSTANT_APP_ADMIN_TOKEN=

# Optionnel : clé pour le bouton 🤖 Claude de l'app de review (crop assisté).
# Sans cette clé, le bouton ne s'affiche pas, le reste fonctionne.
ANTHROPIC_API_KEY=

# Traduction MT du catalogue (scripts/translate-cards-mt.ts) — Azure AI Translator.
# Crée une ressource "Translator" dans le portail Azure, tier F0 (gratuit, 2M car/mois),
# puis copie Key1 + Region. AZURE_TRANSLATOR_REGION requis si la ressource est régionale
# (ex. francecentral, westeurope) ; ENDPOINT optionnel (défaut = endpoint global).
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=
# AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
